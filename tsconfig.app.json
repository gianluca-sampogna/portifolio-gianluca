{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@src/*": ["./src/*"] 
    },
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
"include": [
    "src",
    "src/**/*.ts",    /* Garante que todos os .ts na src sejam lidos */
    "src/**/*.tsx",   /* Garante que todos os .tsx na src sejam lidos */
    "src/**/*.d.ts"   /* Garante que arquivos de definição sejam lidos */
  ]
}